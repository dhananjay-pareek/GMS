# Dashboard Configuration
# Choose between 'sqlite' or 'json' for the jobs list storage.
# Recommended: 'json' for lighter weight.
DB_TYPE=json

# =============================================================================
# WEBHOOK WRITER (Alternative - for separate Leads Manager service)
# =============================================================================
# If you prefer to use a webhook instead of direct database connection.
# Data flow: Scraper → HTTP POST → Leads Manager
# Note: May have timeout issues on free Render tier.
# WEBHOOK_URL=https://your-leadsmanager.onrender.com/api/import

# =============================================================================
# LEADS MANAGER CONFIGURATION (For the Leads Manager service itself)
# =============================================================================
# Local SQLite path used by Leads Manager (and default single-app mode).
# LEADS_DB_PATH=webdata\leadsmanager.db
# Scraper writes directly to this same SQLite DB by default.

# =============================================================================
# SHARED LLM CONFIGURATION (Scraper + Leads Manager)
# =============================================================================
# Works across the single-app setup so you don't need to re-enter keys each time.
# Optional cross-links between UIs:
# SCRAPER_URL=http://localhost:8080
# LEADS_MANAGER_URL=http://localhost:9090
# Defaults are optimized for local Ollama on laptop:
# LLM_PROVIDER=ollama
# OLLAMA_URL=http://localhost:11434
# LLM_MODEL=qwen3-coder:480b-cloud
# For cloud providers, also set:
# LLM_API_KEY=your_api_key_here

# Optional: improves Google PageSpeed Insights reliability/quota for Speed checks.
# PAGESPEED_API_KEY=your_google_pagespeed_key
