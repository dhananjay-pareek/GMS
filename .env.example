# Google Sheets Configuration
# The ID of the spreadsheet where leads will be saved.
# You can find this in the URL of your Google Sheet.
# Example: https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID_HERE/edit
GOOGLE_SHEET_ID=your_spreadsheet_id_here

# Google Cloud Service Account Credentials (JSON string)
# Paste the entire content of your credentials.json here as a single-line string.
# Example: GOOGLE_CREDENTIALS_JSON={"type": "service_account", ...}
# 
# IMPORTANT: Share your Google Sheet with the service account email
# (e.g., your-service@project.iam.gserviceaccount.com) as an Editor!
GOOGLE_CREDENTIALS_JSON=your_service_account_json_content_here

# Dashboard Configuration
# Choose between 'sqlite' or 'json' for the jobs list storage.
# Recommended: 'json' for lighter weight.
DB_TYPE=json

# =============================================================================
# DIRECT SUPABASE WRITER (Recommended - simplest setup)
# =============================================================================
# Set this to write leads directly to your Supabase PostgreSQL database.
# Data flow: Scraper → Supabase (direct connection)
# Your Leads Manager reads from the same database.
# SUPABASE_DB_URL=postgresql://user:pass@host:5432/dbname

# =============================================================================
# WEBHOOK WRITER (Alternative - for separate Leads Manager service)
# =============================================================================
# If you prefer to use a webhook instead of direct database connection.
# Data flow: Scraper → HTTP POST → Leads Manager → Supabase
# Note: May have timeout issues on free Render tier.
# WEBHOOK_URL=https://your-leadsmanager.onrender.com/api/import

# =============================================================================
# LEADS MANAGER CONFIGURATION (For the Leads Manager service itself)
# =============================================================================
# Set these on your Leads Manager instance (not the scraper):
# SUPABASE_DB_URL=postgresql://user:pass@host:5432/dbname
# GOOGLE_SHEET_ID=your_sheet_id (for Google Sheets backup)
# GOOGLE_CREDENTIALS_JSON=your_credentials (for Google Sheets backup)
