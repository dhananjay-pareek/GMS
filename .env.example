# Google Sheets Configuration
# The ID of the spreadsheet where leads will be saved.
# You can find this in the URL of your Google Sheet.
GOOGLE_SHEET_ID=your_spreadsheet_id_here

# Google Cloud Service Account Credentials (JSON string)
# Paste the entire content of your credentials.json here as a single-line string.
# Example: GOOGLE_CREDENTIALS_JSON={"type": "service_account", ...}
GOOGLE_CREDENTIALS_JSON=your_service_account_json_content_here

# Dashboard Configuration
# Choose between 'sqlite' or 'json' for the jobs list storage.
# Recommended: 'json' for lighter weight.
DB_TYPE=json
